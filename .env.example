# L1 RPC URL for L1 contract interactions.
# Local development (npm start): set REACT_APP_L1_RPC_URL — used directly by the
# browser. NOTE: any REACT_APP_* var is baked into the client bundle and visible
# to everyone, so do NOT put a paid/authenticated endpoint here for a deployment.
REACT_APP_L1_RPC_URL=https://your-l1-rpc-url
# Vercel deployment: set L1_RPC_URL_SECRET (no REACT_APP_ prefix, server-side only).
# The frontend talks to /api/l1-rpc, which forwards to this URL. It is NOT in the
# client bundle, so a paid endpoint stays private. Required because the free
# publicnode endpoint only serves eth_getLogs for the last ~100 blocks (archive
# requests beyond that need a token); the BlockProcessed card scans ~7200 blocks.
L1_RPC_URL_SECRET=

# L1 Block Explorer API v2 (for fetching transaction history - much faster than block scanning)
# Supports all chains via chainid parameter: https://api.etherscan.io/v2/api
# Get your API key from: https://etherscan.io/myapikey
REACT_APP_L1_EXPLORER_API_URL=
# Local development: Use REACT_APP_L1_EXPLORER_API_KEY (will be in bundle, OK for dev)
REACT_APP_L1_EXPLORER_API_KEY=
# Vercel deployment: Use L1_EXPLORER_API_KEY (without REACT_APP_ prefix, server-side only)
# Set this in Vercel environment variables - it will NOT be in the client bundle
# L1 Block Explorer base URL (for transaction links)
# Hoodi: https://hoodi.etherscan.io
# Mainnet: https://etherscan.io
REACT_APP_L1_EXPLORER_BASE_URL=

# L2 RPC URL for L2 contract interactions
REACT_APP_L2_RPC_URL=http://your-l2-rpc-url

# L2 Block Explorer URL (for viewing transactions and addresses)
REACT_APP_L2_EXPLORER_URL=https://your-l2-explorer-url

# Block Monitor RPC Endpoints
REACT_APP_GATEWAY_RPC_URL=https://your-gateway-rpc-url
REACT_APP_MAIN_NODE_RPC_URL=http://your-main-node-rpc-url
REACT_APP_TEE_NODE_RPC_URL=http://your-tee-node-rpc-url
# Optional: Second TEE node RPC for monitoring
REACT_APP_TEE_NODE_2_RPC_URL=http://your-second-tee-node-rpc-url
# Optional: Additional follower node RPC (used in Block Information section)
REACT_APP_FOLLOWER_NODE_RPC_URL=http://your-follower-node-rpc-url

# L1 Contract Addresses (Optional - for L1 Contracts management page)
# These addresses are chain-specific and vary across different OP Stack deployments
REACT_APP_L1_ANCHOR_STATE_REGISTRY_ADDRESS=
REACT_APP_L1_DISPUTE_GAME_FACTORY_ADDRESS=
REACT_APP_L1_STANDARD_BRIDGE_ADDRESS=
REACT_APP_L1_OPTIMISM_PORTAL_ADDRESS=
REACT_APP_L1_PROXY_ADMIN_ADDRESS=
REACT_APP_L1_SYSTEM_CONFIG_ADDRESS=
REACT_APP_L1_SUPERCHAIN_CONFIG_ADDRESS=
REACT_APP_L1_SIGNAL_SERVICE_ADDRESS=
# TEE ProverRegistry — enables Signed Proof decoding in Chain Status (optional).
# When set, TEEProverMonitor cross-checks each prover's signature against the registry.
REACT_APP_L1_PROVER_REGISTRY_ADDRESS=
REACT_APP_L1_WORKLOAD_VERIFIER_ADDRESS=

# L2 Contract Addresses (Optional - for chain-specific predeploys)
# Most L2 predeploys have fixed addresses, but some may be chain-specific
REACT_APP_L2_SIGNAL_SERVICE_ADDRESS=

# Chain Status - Role Addresses (for monitoring Batcher and Proposer)
REACT_APP_BATCHER_ADDRESS=
REACT_APP_PROPOSER_ADDRESS=

# Password Protection (Optional - only used in Vercel production deployment)
# Leave empty for local development (no password required)
# Set a password for Vercel deployment to protect the site
# Use ACCESS_PASSWORD (without REACT_APP_ prefix) - this ensures it's server-side only, never in bundle
#
# When ACCESS_PASSWORD is set, the API proxies (/api/l1-rpc, /api/rpc-proxy,
# /api/explorer-proxy) ALSO require a valid signed auth cookie issued on login,
# so they can't be called directly by anyone who knows the deployment URL.
# When it is empty, both the UI gate and the proxy guard are disabled (open).
ACCESS_PASSWORD=
# Optional: dedicated secret for signing the auth cookie (HMAC key). If unset,
# ACCESS_PASSWORD is used as the signing key. Set a long random value in Vercel
# for separation; changing it invalidates all existing sessions.
AUTH_SECRET=
